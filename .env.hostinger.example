# App runtime
KTOR_ENV=docker
APP_PORT=80

# Database for Ktor app
DB_URL=jdbc:postgresql://db:5432/template_db
DB_USER=template_user
DB_PASSWORD=change_me

# PostgreSQL container bootstrap
POSTGRES_DB=template_db
POSTGRES_USER=template_user
POSTGRES_PASSWORD=change_me

# Optional project identifier used in compose resource names
HOSTINGER_PROJECT_NAME=ktor_backend_template

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
APP_BASE_URL=https://api.yourdomain.com

# eBay Marketplace (https://developer.ebay.com)
EBAY_CLIENT_ID=ebay_your_client_id
EBAY_CLIENT_SECRET=ebay_your_client_secret
EBAY_OAUTH_ENDPOINT=https://api.ebay.com/identity/v1/oauth2/token
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENVIRONMENT=SANDBOX
EBAY_MAX_RESULTS=10
EBAY_FEED_PAGES=5
EBAY_FEED_REFRESH_INTERVAL_SECONDS=600
