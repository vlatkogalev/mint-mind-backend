# --- App Runtime ---
KTOR_ENV=local
PORT=8080

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/mint_mind
DB_USER=mint_mind_user
DB_PASSWORD=change_me

# --- Auth (JWT) ---
AUTH_SECRET=your_256_bit_secret_key_replace_me
AUTH_ISSUER=mint-mind-backend
AUTH_AUDIENCE=mint-mind-app
AUTH_REALM=mint-mind
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Email (Resend) ---
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@mintmind.app
APP_BASE_URL=http://localhost:8080
APP_ENV=local

# --- AWS S3 ---
AWS_REGION=us-east-1
AWS_BUCKET=mint-mind-coins-bucket
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_UPLOAD_URL_TTL_SECONDS=900
AWS_DOWNLOAD_URL_TTL_SECONDS=900
AWS_AWS_CLOUDFRONT_DOMAIN=d1234567890.cloudfront.net

# --- eBay ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_OAUTH_ENDPOINT=https://api.ebay.com/identity/v1/oauth2/token
EBAY_OAUTH_SCOPE=https://api.ebay.com/oauth/api_scope
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENVIRONMENT=SANDBOX
EBAY_MAX_RESULTS=10
EBAY_FEED_PAGES=5
EBAY_FEED_REFRESH_INTERVAL_SECONDS=600

# --- Numista ---
NUMISTA_API_KEY=
NUMISTA_BASE_URL=https://api.numista.com

# --- RevenueCat ---
REVENUECAT_WEBHOOK_SECRET=
