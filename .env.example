# Local development configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# App environment (set to "local" to skip email verification)
APP_ENV=local

# ── Database ──────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/mintmind
DB_USER=mintmind
DB_PASSWORD=mintmind

# ── Auth (optional, defaults work for local dev) ──
# AUTH_SECRET=mintmind-auth_secret
# AUTH_ISSUER=mintmind-service
# AUTH_AUDIENCE=mintmind-users

# ── Email / Resend ────────────────────────────────
# Not required when APP_ENV=local (verification is skipped)
# RESEND_API_KEY=re_your_api_key_here
# EMAIL_FROM=noreply@mintmind.app
# APP_BASE_URL=http://localhost:8080

# ── eBay Marketplace ──────────────────────────────
EBAY_CLIENT_ID=your_ebay_sandbox_client_id
EBAY_CLIENT_SECRET=your_ebay_sandbox_client_secret
# EBAY_ENVIRONMENT=SANDBOX
# EBAY_MARKETPLACE_ID=EBAY_US

# ── Numista API ───────────────────────────────────
NUMISTA_API_KEY=your_numista_api_key

# ── AWS S3 ────────────────────────────────────────
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_BUCKET=mint-mind-coins-bucket
